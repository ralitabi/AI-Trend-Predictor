# Copy to .env and fill in. Without a key, the app still runs (technical signals only).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Durable history (optional). Without these, prediction/accuracy/paper-trade
# history is stored in a local SQLite file that resets on serverless cold starts.
# Point at a free Turso/libSQL database to persist it (see DEPLOY.md §3).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Alerts (optional). When set, signal-flip / price alerts are also relayed to
# these channels by POST /notify. Leave blank to use browser notifications only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Per-category signal groups (optional). Route Telegram signals to a separate
# group per asset class; any class left blank falls back to TELEGRAM_CHAT_ID.
TELEGRAM_CHAT_CRYPTO=
TELEGRAM_CHAT_FOREX=
TELEGRAM_CHAT_COMMODITY=
TELEGRAM_CHAT_INDEX=
TELEGRAM_CHAT_STOCK=

# Continuous collection (optional). If set, the /snapshot collector endpoint
# requires this secret (Vercel Cron sends it automatically; an external pinger
# passes ?secret=...). Leave blank to leave /snapshot open. See DEPLOY.md §4.
CRON_SECRET=
