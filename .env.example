# ═══════════════════════════════════════════════════════════════
#  AI Trend Predictor — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── AI Report Generation (Optional) ──────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Without this key the app still works — it uses template reports.
OPENAI_API_KEY=sk-proj-...

# ── Macroeconomic Data (Optional) ─────────────────────────────
# FRED API for real inflation and interest rate data.
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Asset Tickers ──────────────────────────────────────────────
# Yahoo Finance ticker symbols (defaults work out of the box)
GOLD_TICKER=GC=F
SP500_TICKER=^GSPC
BITCOIN_TICKER=BTC-USD

# ── Model Configuration ────────────────────────────────────────
ARIMA_ORDER=5,1,2
LOOKBACK_DAYS=730
FORECAST_DAYS=7

# ── Risk Configuration ─────────────────────────────────────────
RISK_FREE_RATE=0.05
CONFIDENCE_LEVEL=0.95

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=WARNING
